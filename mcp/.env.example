# ThePopeBot MCP bridge config. Copy to `.env` (gitignored) and fill in.
# The bridge also reads these straight from the process environment if set there.

# Where ThePopeBot's event handler is reachable (no trailing slash).
# Local dev default is the Next.js server; in prod use your domain.
POPEBOT_API_URL=http://localhost:3000

# A user-owned ThePopeBot API key (create one in the admin UI -> API keys).
# This is the x-api-key sent on every request. Keep it secret.
POPEBOT_API_KEY=

# Optional: per-request timeout in milliseconds (default 30000).
POPEBOT_TIMEOUT_MS=30000
